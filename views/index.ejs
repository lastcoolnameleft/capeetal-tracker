<%- include ('includes/header.ejs', {isIndex: true, isMap: true}) %>

    <div id="wrapper">
        <!-- Main -->
        <section id="main" class="wrapper" role="main">
            <div class="inner center">
                <script>
                    is_share_page = <%= is_share_page %>;

                    function share() {
                        const activeRegions = countActiveLocations(regionArray);
                        const totalRegions = regionArray.length;
                        const amount = getAmount(activeRegions, totalRegions, volumeHash, activeRegions * 8, true)
                        const shareData = {
                           url: getShareUrl(),
                           text: amount,
                           title: 'Join the Uri-nation Nation!',
                        };
                        navigator.share(shareData)
                            .then(() => console.log('Successful share'))
                            .catch((error) => console.log('Error sharing', error));
                    }

                </script>
                    <h2>Welcome to the Ca-PEE-tal Tracker where you track each US state capital you've urinated!</h2>
                    <div class="progress-container" id="progress-container" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="50" aria-label="Capital cities visited progress">
                        <div class="progress-text"><span id="progress-count">0</span> / <span id="progress-total">50</span> capitals visited</div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="progress-fill"></div>
                        </div>
                    </div>
                    <h3 style="color: var(--color-primary);" id="amount" aria-live="polite"></h3>
                    <div id="loading-spinner" class="spinner-container" role="status" aria-label="Loading map">
                        <div class="spinner" aria-hidden="true"></div>
                        <p>Loading map...</p>
                    </div>
                    <div id="regions_div" role="img" aria-label="Interactive map of US states showing visited capitals"></div>
                    <div class="state-grid" id="stateGrid" role="group" aria-label="Select state capitals you have visited">
                        <% for (const [code, name] of Object.entries(regionHash)) { %>
                            <button class="state-chip" id="chip-<%= code.toLowerCase() %>" onclick="toggleRegion(regionArray, '<%= code %>');" aria-pressed="false" aria-label="<%= name %>, <%= code %>">
                                <span class="chip-code"><%= code %></span>
                                <span class="chip-name"><%= name %></span>
                            </button>
                        <% } %>
                    </div>
                    <br>
                    <br>
                    <button
                        onclick="share()" class="button" aria-label="Share your progress">Click here to overshare!</button>
                    <br>
                    <nav aria-label="Share on social media">
                    <ul class="share-buttons" >
                        <li><a class="no-border-bottom" href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fcapeetaltracker.com%2F&quote="
                                title="Share on Facebook" target="_blank" rel="noopener noreferrer"
                                onclick="window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(getShareUrl()) + '&quote=' + encodeURIComponent(getShareUrl())); return false;"><img
                                    alt="Share on Facebook" src="/images/share/facebook.png" /></a></li>
                        <li><a class="no-border-bottom" href="mailto:?subject=&body=:%20https%3A%2F%2Fcapeetaltracker.com%2F" target="_blank"
                                title="Send email"
                                onclick="window.open('mailto:?subject=' + encodeURIComponent(getShareTitle()) + '&body=' +  encodeURIComponent(getShareUrl())); return false;"><img
                                    alt="Send email" src="images/share/email.png" /></a></li>
                        <li><a class="no-border-bottom" href="http://www.tumblr.com/share?v=3&u=https%3A%2F%2Fcapeetaltracker.com&quote=&s="
                                target="_blank" title="Post to Tumblr" rel="noopener noreferrer"
                                onclick="window.open('http://www.tumblr.com/share?v=3&u=' + encodeURIComponent(getShareUrl()) + '&quote=' +  encodeURIComponent(getShareTitle())); return false;"><img
                                    alt="Post to Tumblr" src="images/share/tumblr.png" /></a></li>
                        <li>
                            <div class="tooltip">
                                <button class="copy-link-btn" onclick="copyButton()" onmouseout="onMouseOutLinkShare()" aria-label="Copy share link to clipboard">
                                    <img src="/images/share/link.png" alt="Copy link">
                                </button>
                                <span class="tooltiptext" id="myTooltip" role="tooltip">Press to copy</span>
                            </div>
                        </li>
                    </ul>
                    </nav>
            </div>
        </section>
    </div>

    <%- include ('includes/footer.ejs') %>