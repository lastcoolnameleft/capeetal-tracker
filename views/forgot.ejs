<%- include ('includes/header.ejs', {}) %>

<div id="wrapper">
    <section id="main" class="wrapper">
        <div class="inner center">
            <h2>Forgot Password</h2>

            <% if (error) { %>
                <div class="auth-error" role="alert"><%= error %></div>
            <% } %>

            <% if (success) { %>
                <div class="auth-success" role="status">If an account with that email exists, a reset link has been sent. Check your email (or server logs in dev mode).</div>
            <% } else { %>
            <form action="/auth/forgot" method="POST" class="auth-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="auth-field">
                    <label for="email">Email address</label>
                    <input type="email" id="email" name="email" required autocomplete="email">
                </div>
                <button type="submit" class="auth-btn auth-btn-primary">Send Reset Link</button>
            </form>
            <% } %>

            <p class="auth-link"><a href="/auth/login">Back to login</a></p>
        </div>
    </section>
</div>

<%- include ('includes/footer.ejs') %>
